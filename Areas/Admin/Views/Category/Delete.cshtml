@model Category

<h1>Delete Category</h1>

<div class="border-bottom colcol-md-10 mx-auto">

    <form asp-action="Delete">

        <input type="hidden" asp-for="CategoryId" />

        <div class="form-group m-4">
            <label asp-for="Name" class="control-label col-md-2"> </label>
            <div>
                <input asp-for="Name" disabled class="form-control col-6" />
            </div>
        </div>

        <div class="form-group m-4">
            <label class="control-label col-6">Description</label>
            <div>
                <input asp-for="Description" disabled class="form-control col-6" />
            </div>
        </div>


        <div class="form-group m-4">
            <input type="submit" value="Delete Category" class="form-control btn btn-danger col-6" />
        </div>
    </form>
</div>