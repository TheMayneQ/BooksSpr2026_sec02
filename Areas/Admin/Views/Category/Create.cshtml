@model Category

<h1>Create New Category</h1>

<div class="border-bottom colcol-md-10 mx-auto">

<form asp-action="Create">

    <div asp-validation-summary="All" class="text-danger">

    </div>

    <div class="form-group m-4">
    <label asp-for="Name" class="control-label col-md-2"> </label>
        <div>
            <input asp-for="Name" class="form-control col-6"/>
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
    </div>

    <div class="form-group m-4">
    <label class="control-label col-6">Description</label>
        <div>
            <input asp-for="Description" class="form-control col-6"/>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
    </div>


    <div class="form-group m-4">
        <input type="submit" value="Create New Category" class="form-control btn btn-outline-primary col-6" />
    </div>
</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
</div>